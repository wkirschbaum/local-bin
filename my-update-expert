#!/usr/bin/env bash
#
# my-update-expert — fetch the latest Expert (Elixir LSP) nightly into
# ~/.local/bin/expert.  Uses anonymous curl: no GitHub auth required,
# so this works fine from a systemd timer when 1Password is locked.
#
# Source: https://github.com/expert-lsp/expert

set -euo pipefail

URL="https://github.com/expert-lsp/expert/releases/download/nightly/expert_linux_amd64"
BIN="${HOME}/.local/bin/expert"

mkdir -p "$(dirname "$BIN")"

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

echo "my-update-expert: fetching $URL"
curl -fsSL --retry 3 --retry-delay 2 -o "$tmp" "$URL"

# Skip the install step if the asset is byte-identical to what's
# already on disk — keeps mtime stable and avoids touching the binary
# while a running emacs has it open.
if [[ -f "$BIN" ]] && cmp -s "$tmp" "$BIN"; then
  echo "my-update-expert: already up to date"
  exit 0
fi

install -m 0755 "$tmp" "$BIN"
echo "my-update-expert: installed $("$BIN" --version 2>/dev/null || echo nightly)"
